from flask import Flask, render_template, request, redirect, url_for, session, flash
from database import register as db_register, login as db_login

app = Flask(__name__)
app.secret_key = "Sup@duka123!!"

# ── Index Route ── footer SHOWS ──
@app.route('/home')
def index():
    if "username" in session:
        return redirect(url_for('dashboard'))
    return render_template('index.html')              

# ── Register Route ── footer HIDDEN ──
@app.route('/register', methods=['GET', 'POST'])
def register_page():
    if request.method == 'POST':
        username         = request.form['username']
        email            = request.form['email']
        password         = request.form['password']
        confirm_password = request.form['confirm_password']

        if password != confirm_password:
            return render_template('register.html',
                                   error='Passwords do not match!',
                                   hide_footer=True)   
        result = db_register(username, email, password, confirm_password)
        if result:
            return redirect(url_for('login_page'))
        else:
            return render_template('register.html',
                                   error='User already exists!',
                                   hide_footer=True)   

    return render_template('register.html', hide_footer=True)  


# ── Login Route ── footer HIDDEN ──
@app.route('/login', methods=['GET', 'POST'])
def login_page():
    if request.method == 'POST':
        username = request.form['username']
        password = request.form['password']

        user = db_login(username, password)
        if user:
            session['username'] = user.username
            return redirect(url_for('dashboard'))
        else:
            return render_template('login.html',
                                   error="Invalid username or password!",
                                   hide_footer=True)   

    return render_template('login.html', hide_footer=True)     


# ── Dashboard Route ── footer HIDDEN ──
@app.route('/dashboard')
def dashboard():
    if 'username' not in session:
        return redirect(url_for('index.html'))
    return render_template('dashboard.html',
                           hide_footer=True,          
                           username=session['username'])


# ── Logout Route ──
@app.route('/logout')
def logout():
    # Clear the session
    session.clear()
    # Show success message
    flash('You have been logged out successfully!', 'success')
    # Redirect to login page
    return redirect(url_for('/')) 


if __name__ == "__main__":
    app.run(debug=True)

